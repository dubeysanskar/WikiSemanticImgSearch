# Wikimedia API Configuration
# Copy this file to .env.local and fill in your values

# Your MediaWiki username (REQUIRED for User-Agent compliance)
MEDIAWIKI_USERNAME=YourUsername

# JWT Secret for authentication (use a strong random string)
JWT_SECRET=your-secret-key-here

# SMTP Configuration (for OTP emails)
# For Gmail: use an App Password from https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=WikiSemanticImgSearch <your-email@gmail.com>

# Database — Turso (for Vercel deployment)
# Sign up free at https://turso.tech and create a database
# Leave empty for local SQLite file (dev mode)
# TURSO_DATABASE_URL=libsql://your-db-name.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token

# Optional: Override default API timeout (milliseconds)
# API_TIMEOUT=12000

# Optional: Maximum results per search
# MAX_RESULTS=40
