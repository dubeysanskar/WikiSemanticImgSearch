# MediaWiki API Etiquette — your Wikimedia username
MEDIAWIKI_USERNAME=YourWikiUsername

# Wikimedia OAuth 2.0
# Register at: https://meta.wikimedia.org/wiki/Special:OAuthConsumerRegistration/propose/oauth2
# Select: "User identity verification only with access to real name and email address"
# Callback URL: https://your-domain/api/auth/callback/wikimedia
WIKIMEDIA_CLIENT_ID=your_client_id_here
WIKIMEDIA_CLIENT_SECRET=your_client_secret_here

# NextAuth.js
NEXTAUTH_SECRET=generate_a_random_secret_here
NEXTAUTH_URL=http://localhost:3000

# Database — Turso (cloud SQLite for Vercel deployment)
# Sign up free at https://turso.tech
# Locally uses SQLite file (wikisearch.db) — no config needed
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your_turso_token
